{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "Band tour dates and events",
      "type": "object",
      "properties": {
        "city": { "type": "string", "description": "City of the event" },
        "venue": { "type": "string", "description": "Venue name" },
        "date": { "type": "string", "format": "date", "description": "Date of the event" },
        "ticketUrl": { "type": "string", "description": "URL to purchase tickets" },
        "imageUrl": { "type": "string", "description": "URL for tour poster" },
        "status": { "type": "string", "enum": ["upcoming", "cancelled", "completed"], "description": "Status of the event" },
        "createdAt": { "type": "string", "description": "Timestamp of creation" }
      },
      "required": ["city", "venue", "date", "status"]
    },
    "MerchItem": {
      "title": "Merch Item",
      "description": "Band merchandise products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "price", "imageUrl", "stock"]
    },
    "NewsPost": {
      "title": "News Post",
      "description": "News updates from the band",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "publishDate": { "type": "string" },
        "author": { "type": "string" }
      },
      "required": ["title", "content", "publishDate", "author"]
    },
    "FanMessage": {
      "title": "Fan Message",
      "description": "Messages sent by fans via contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "Images for the band gallery",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "caption": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["url", "createdAt"]
    },
    "BandMember": {
      "title": "Band Member",
      "description": "Information about a band member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "instruments": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "bio": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "role", "imageUrl", "createdAt"]
    }
  },
  "firestore": {
    "events": {
      "schema": "Event",
      "description": "Collection of tour dates"
    },
    "merchandise": {
      "schema": "MerchItem",
      "description": "Collection of band merchandise"
    },
    "news": {
      "schema": "NewsPost",
      "description": "Collection of band news"
    },
    "fanMessages": {
      "schema": "FanMessage",
      "description": "Collection of messages from contact form"
    },
    "gallery": {
      "schema": "GalleryImage",
      "description": "Collection of gallery images"
    },
    "members": {
      "schema": "BandMember",
      "description": "Collection of band members"
    }
  }
}
